###  https://www.dei.unipd.it/Database2/CPS-NBA/name
:name rdf:type owl:DatatypeProperty ;
      rdfs:domain [ owl:intersectionOf ( [ rdf:type owl:Class ;
                                           owl:unionOf ( :Arena
                                                         :Country
                                                         :Person
                                                       )
                                         ]
                                         [ rdf:type owl:Class ;
                                           owl:complementOf [ owl:intersectionOf ( :Arena
