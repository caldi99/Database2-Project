                                           owl:complementOf [ owl:intersectionOf ( :Arena
                                                                                   :Country
                                                                                   :Person
                                                                                 ) ;
                                                              rdf:type owl:Class
                                                            ]
                                         ]
                                         [ rdf:type owl:Class ;
                                           owl:complementOf [ owl:intersectionOf ( :Arena
                                                                                   :Person
                                                                                 ) ;
                                                              rdf:type owl:Class
                                                            ]
                                         ]
                                         [ rdf:type owl:Class ;
                                           owl:complementOf [ owl:intersectionOf ( :Country
                                                                                   :Person
                                                                                 ) ;
                                                              rdf:type owl:Class
                                                            ]
                                         ]
                                       ) ;
                    rdf:type owl:Class
                  ] ;
      rdfs:range xsd:string .


